#!/bin/sh
set -eu

ROOT=$(CDPATH= cd -- "$(dirname -- "$0")/.." && pwd)
REMOTE=${DOTFILES_SYNC_REMOTE:-origin}
BRANCH=${DOTFILES_SYNC_BRANCH:-main}
LOG_DIR=${DOTFILES_SYNC_LOG_DIR:-$HOME/.local/state}
LOG_FILE=${DOTFILES_SYNC_LOG_FILE:-$LOG_DIR/dotfiles-sync.log}
LOCK_DIR=${DOTFILES_SYNC_LOCK_DIR:-$HOME/.cache/dotfiles-sync.lock}
PATH="$HOME/.local/bin:/opt/homebrew/bin:/opt/homebrew/sbin:/usr/local/bin:/usr/local/sbin:/home/linuxbrew/.linuxbrew/bin:/home/linuxbrew/.linuxbrew/sbin:/usr/bin:/bin:/usr/sbin:/sbin${PATH:+:$PATH}"
export PATH

mkdir -p "$LOG_DIR"
mkdir -p "$(dirname "$LOCK_DIR")"

timestamp() {
    date '+%Y-%m-%d %H:%M:%S%z'
}

log() {
    line="$(timestamp) $*"
    printf '%s\n' "$line" | tee -a "$LOG_FILE"
}

cleanup() {
    rmdir "$LOCK_DIR" 2>/dev/null || true
}

if ! mkdir "$LOCK_DIR" 2>/dev/null; then
    log "skip  sync already running"
    exit 0
fi
trap cleanup EXIT INT TERM HUP

cd "$ROOT"

if ! git rev-parse --is-inside-work-tree >/dev/null 2>&1; then
    log "error not a git repository: $ROOT"
    exit 1
fi

current_branch=$(git rev-parse --abbrev-ref HEAD)
if [ "$current_branch" != "$BRANCH" ]; then
    log "error expected branch $BRANCH, got $current_branch"
    exit 1
fi

machine_name=$(hostname -s 2>/dev/null || hostname 2>/dev/null || uname -n)
commit_time=$(date '+%Y-%m-%dT%H:%M:%S%z')
commit_message="auto(dotfiles): ${machine_name} ${commit_time}"

is_dirty=0
if ! git diff --quiet --ignore-submodules --; then
    is_dirty=1
fi
if ! git diff --cached --quiet --ignore-submodules --; then
    is_dirty=1
fi
if [ -n "$(git ls-files --others --exclude-standard)" ]; then
    is_dirty=1
fi

if [ "$is_dirty" -eq 1 ]; then
    log "commit local changes"
    git add -A
    if git diff --cached --quiet --ignore-submodules --; then
        log "skip  nothing staged after add"
    else
        git -c commit.gpgsign=false commit -m "$commit_message" >>"$LOG_FILE" 2>&1
    fi
fi

log "fetch $REMOTE/$BRANCH"
git fetch "$REMOTE" "$BRANCH" >>"$LOG_FILE" 2>&1

log "rebase onto $REMOTE/$BRANCH"
if ! git rebase "$REMOTE/$BRANCH" >>"$LOG_FILE" 2>&1; then
    git rebase --abort >>"$LOG_FILE" 2>&1 || true
    log "error rebase failed; manual resolution required"
    exit 1
fi

log "push $REMOTE $BRANCH"
if ! git push "$REMOTE" "$BRANCH" >>"$LOG_FILE" 2>&1; then
    log "error push failed; will retry on next run"
    exit 1
fi

log "done  sync complete"
